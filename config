ngx_addon_name=ngx_http_htaccess_module

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_htaccess_module
    ngx_module_srcs="$ngx_addon_dir/ngx_http_htaccess_module.c \
                     $ngx_addon_dir/ngx_http_htaccess_parser.c \
                     $ngx_addon_dir/ngx_http_htaccess_rewrite.c \
                     $ngx_addon_dir/ngx_http_htaccess_access.c \
                     $ngx_addon_dir/ngx_http_htaccess_header.c \
                     $ngx_addon_dir/ngx_http_htaccess_cache.c"
    ngx_module_libs="PCRE -lcrypt"

    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_htaccess_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS \
                    $ngx_addon_dir/ngx_http_htaccess_module.c \
                    $ngx_addon_dir/ngx_http_htaccess_parser.c \
                    $ngx_addon_dir/ngx_http_htaccess_rewrite.c \
                    $ngx_addon_dir/ngx_http_htaccess_access.c \
                    $ngx_addon_dir/ngx_http_htaccess_header.c \
                    $ngx_addon_dir/ngx_http_htaccess_cache.c"
fi
